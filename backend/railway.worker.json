{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "startCommand": "python -m workers.softoptic_migration_worker",
    "ipv6EgressEnabled": true,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
